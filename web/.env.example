# Copy to .env.local and fill in. Never commit .env.local.

# Full URL for booking (Cal.com, Calendly, etc.). If unset, primary CTA scrolls to #book-audit.
# NEXT_PUBLIC_SCHEDULE_AUDIT_URL=https://cal.com/your-org/audit

# If set, “Get in touch” uses mailto:. If unset, links to #contact in the footer.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Optional: set in Vercel to your production URL for correct OG canonical URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
