# Copy to `.env` or `.env.local` in this folder and fill in. Never commit real secrets.
# `web/.gitignore` ignores `.env` and `.env.local`; only `.env.example` is tracked.

# ------------------------------------------------------------------------------
# Site / contact (existing)
# ------------------------------------------------------------------------------

# If set, “Get in touch” uses mailto:. If unset, links to #contact in the footer.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Optional: production site origin for OG / metadata (Vercel Production).
# Use a full URL (https://…) or a bare host (your-domain.com); invalid values fall back to localhost in dev.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Full URL for primary “Schedule audit” CTAs (Cal.com, etc.). If unset, CTAs fall back to #book-audit.
# Until Cal embed wiring lands, set this to your Cal booking link (can match NEXT_PUBLIC_CAL_BOOKING_URL).
# NEXT_PUBLIC_SCHEDULE_AUDIT_URL=https://cal.com/your-org/your-event-slug

# Public n8n form URL used by the `/getstarted` page iframe.
# NEXT_PUBLIC_N8N_FORM_URL=https://aibuddyopt.app.n8n.cloud/form/fcb32890-4c02-400c-a8aa-a838191ab54e

# ------------------------------------------------------------------------------
# Cal.com — public (safe to expose to the browser; use NEXT_PUBLIC_* only)
# ------------------------------------------------------------------------------

# Event booking page URL (modal + fallback). Required once Cal booking is wired up.
# NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/your-org/your-event-slug

# Optional: event type slug if embed/init code needs it separately from the full URL.
# NEXT_PUBLIC_CAL_EVENT_TYPE_SLUG=your-event-slug

# Header “Schedule audit” only — redirect target (future /book page or temporary Cal link).
# NEXT_PUBLIC_SCHEDULE_AUDIT_HEADER_URL=https://cal.com/your-org/your-event-slug

# Enable Cal popup/modal embed: true | false
# NEXT_PUBLIC_CAL_EMBED_ENABLED=true

# ------------------------------------------------------------------------------
# Cal.com — server-only (never prefix with NEXT_PUBLIC_ ; never expose to client)
# ------------------------------------------------------------------------------

# API key for server routes / future webhooks integration (optional until you use server Cal API).
# CAL_API_KEY=

# Optional override if your Cal deployment uses a non-default API base URL.
# CAL_API_BASE_URL=https://api.cal.com
