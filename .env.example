# Contact form → n8n webhook
# Copy this file to .env.local and fill in your values.

# The Production webhook URL from your n8n "Webhook" trigger node.
# Example: https://your-instance.app.n8n.cloud/webhook/contact
N8N_WEBHOOK_URL=

# Optional shared secret. If set, it is sent as the "x-webhook-secret" header.
# Verify it inside your n8n workflow (IF node) to reject forged requests.
N8N_WEBHOOK_SECRET=
